# Logs
# (NOTE: a bare "logs" here also ignored apps/web/src/features/logs/ — the Logs
# surface — silently dropping it from git. Scope the ignore to log FILES only.)
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
