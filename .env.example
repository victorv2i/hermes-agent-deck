# Agentdeck — example environment file.
#
# Copy to `.env` and edit only what you need. Every var below is OPTIONAL:
# with Hermes running on its defaults, Agentdeck needs no configuration.
# This file contains NO secrets — never commit a real `.env`.

# ── Bind (where Agentdeck listens) ──────────────────────────────────────────

# Bind host. Loopback (the default) is frictionless and this-machine-only.
# Set a *.ts.net host or LAN IP for remote access (turns on the auth gate).
# A broad wildcard (0.0.0.0 / ::) is refused unless AGENT_DECK_UNSAFE_BIND=1.
AGENT_DECK_HOST=127.0.0.1

# Bind port.
AGENT_DECK_PORT=7878

# Bearer token required on a NON-loopback bind. Leave unset on a remote bind to
# have the server print a fresh one once at startup, or pin your own here.
# Ignored on a loopback bind (no token needed). NOT a secret default — set your own.
# AGENT_DECK_TOKEN=

# ── Hermes connection (override only if your Hermes is non-default) ───────────

# Hermes chat gateway (/v1/runs). Leave unset and the deck auto-detects the port
# from your ~/.hermes/config.yaml (API_SERVER_PORT), falling back to stock 8642.
HERMES_GATEWAY_URL=http://127.0.0.1:8642

# Hermes dashboard data API (sessions, config, models, usage). Stock port is 9119.
HERMES_DASHBOARD_URL=http://127.0.0.1:9119

# Host header the dashboard expects to authorize the browser-session check.
HERMES_DASHBOARD_HOST=127.0.0.1:9119

# Hermes home directory (profile-aware). Defaults to ~/.hermes.
# HERMES_HOME=

# ── Multiple agents, instant switching (optional) ────────────────────────────

# Run one gateway PER agent profile on its own port and the deck switches agents
# by routing to the active profile's gateway — no restart. By default the deck
# discovers each named profile's port from its own ~/.hermes/profiles/<name>/
# config.yaml (API_SERVER_PORT). Use this only to OVERRIDE that mapping, as a
# comma-separated list of profile=port pairs. The default profile uses
# HERMES_GATEWAY_URL above.
# AGENT_DECK_GATEWAY_PORTS=default=8642,work=8643
